# Aethernal — Umgebungsvariablen (Vorlage — echte Werte NIE committen!)

# Supabase (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Basis-URL der App (Auth-Redirects, Links in E-Mails)
NEXT_PUBLIC_APP_URL=https://app.aethernal.me

# NUR SERVERSEITIG (niemals NEXT_PUBLIC!): Admin-Key für die
# Konto-Löschung (app/api/account/delete). Umgeht RLS — streng geheim.
SUPABASE_SERVICE_ROLE_KEY=

# NUR SERVERSEITIG: Resend-Key für Einladungs-/Bestätigungs-Mails (B2)
RESEND_API_KEY=
FROM_EMAIL="Aethernal <noreply@aethernal.me>"

# Edge Function `send-due-messages`: Secrets liegen NICHT hier, sondern
# werden per `supabase secrets set` gesetzt:
#   RESEND_API_KEY   (re_...)
#   FROM_EMAIL       (z. B. "Aethernal <noreply@aethernal.me>")
#   CRON_SECRET      (langes Zufalls-Secret, identisch im Cron-Job)
